<script>
(function(){
    var cookieName = 'compose_manager_settings_return';
    function getSafeReturnPath() {
        if (!document.referrer || document.referrer === window.location.href) {
            return null;
        }
        try {
            var ref = new URL(document.referrer, window.location.origin);
            if (ref.origin !== window.location.origin) return null;
            var p = ref.pathname.replace(/\/+$/, '');
            if (p === '' || p === '/') return '/Settings';

            var allowed = [
                '/Settings',
                '/Plugins',
                '/Docker',
                '/Compose',
                '/Dashboard',
            ];

            for (var i = 0; i < allowed.length; i++) {
                if (p.toLowerCase() === allowed[i].toLowerCase()) {
                    return ref.pathname + (ref.search || '');
                }
                if (allowed[i].toLowerCase().endsWith('/') && p.toLowerCase().startsWith(allowed[i].toLowerCase())) {
                    return ref.pathname + (ref.search || '');
                }
            }

            if (p.toLowerCase().startsWith('/plugins')) {
                return ref.pathname + (ref.search || '');
            }
            return null;
        } catch (e) {
            return null;
        }
    }

    var existingPath = $.cookie(cookieName);
    var safePath = getSafeReturnPath();
    var returnPath;

    if (safePath) {
        returnPath = safePath;
    } else if (existingPath) {
        returnPath = existingPath;
    } else {
        returnPath = '/Settings';
    }

    $.cookie(cookieName, returnPath, { path: '/' });

    var originalDone = window.done;
    window.done = function(k) {
        var saved = $.cookie(cookieName);
        if (saved) {
            $.removeCookie(cookieName, { path: '/' });
            if (saved !== '' && saved !== window.location.pathname) {
                location.replace(saved);
                return;
            }
        }
        if (typeof originalDone === 'function') {
            originalDone(k);
        } else if (k) {
            var url = location.pathname.split('/');
            var path = '/' + url[1];
            for (var i = 2; i < url.length; i++) {
                if (url[i] == k) break;
                path += '/' + url[i];
            }
            $.removeCookie('one');
            location.replace(path);
        } else {
            $.removeCookie('one');
            location.replace('/Settings');
        }
    };
})();
</script>

