    <script>
        (function() {
            var repo = 'mstrhakr/compose_plugin';
            var perPage = 10;
            var $list = $('#contributors-list');

            function showFallback() {
                $list.html('<p>Unable to load contributors. View on GitHub: <a href="https://github.com/' + repo + '/graphs/contributors" target="_blank" rel="noopener noreferrer">' + repo + ' — Contributors</a></p>');
            }

            // Use GitHub public contributors API (CORS-enabled). Limit to top N contributors.
            $.getJSON('https://api.github.com/repos/' + repo + '/contributors?per_page=' + perPage)
                .done(function(data) {
                    if (!data || !data.length) {
                        $list.html('<p>No contributors found. <a href="https://github.com/' + repo + '/graphs/contributors" target="_blank" rel="noopener noreferrer">View on GitHub</a></p>');
                        return;
                    }

                    var html = '<ul style="list-style:none;padding:0;margin:0;display:flex;flex-wrap:wrap;gap:10px;">';
                    data.forEach(function(u) {
                        var login = u.login || '';
                        var url = u.html_url || 'https://github.com/' + login;
                        var avatar = (u.avatar_url || '').replace(/&s=\d+/, '') + '&s=96';
                        var contributions = u.contributions || 0;

                        html += '<li style="width:220px;border:1px solid var(--dynamix-box-inner-div-border-color);padding:8px;border-radius:6px;display:flex;gap:8px;align-items:center;">' +
                            '<a href="' + url + '" target="_blank" rel="noopener noreferrer"><img src="' + avatar + '" alt="' + login + '" style="width:48px;height:48px;border-radius:4px;"></a>' +
                            '<div style="flex:1;min-width:0;overflow:hidden;">' +
                            '<a href="' + url + '" target="_blank" rel="noopener noreferrer" style="font-weight:600;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + login + '</a>' +
                            '<span style="color: var(--dynamix-sb-title-text-color);font-size:0.9em;">' + contributions + ' contributions</span>' +
                            '</div>' +
                            '</li>';
                    });
                    html += '</ul>';
                    $list.html(html);
                })
                .fail(function() {
                    showFallback();
                });
        })();
    </script>

    <div class="credits-section" style="padding:12px;">
        <h3>Build &amp; Packaging</h3>
        <ul>
            <li>`pkg_build.sh` — packaging helper used when assembling plugin releases.</li>
            <li><a href="https://github.com/ajaxorg/ace-builds" target="_blank" rel="noopener noreferrer">ace-builds</a> — source for the bundled Ace editor files.</li>
        </ul>
        <p>If you maintain packaging scripts or upstream libraries we reference and would like a more explicit mention, let me know and I'll add it.</p>
    </div>


    <script>
        (function() {
            function setVersion(v) {
                if (!v) v = 'unknown';
                $('#ace-version').text(v);
            }

            // Try direct properties and common module locations
            try {
                if (window.ace) {
                    if (ace.version) return setVersion(ace.version);
                    if (ace.config && ace.config.version) return setVersion(ace.config.version);
                    try {
                        if (ace.require) {
                            var verMod = null;
                            try {
                                verMod = ace.require('ace/lib/version');
                            } catch (e) {}
                            if (!verMod) try {
                                verMod = ace.require('ace/config');
                            } catch (e) {}
                            if (verMod) {
                                if (typeof verMod === 'string') return setVersion(verMod);
                                if (verMod.version) return setVersion(verMod.version);
                            }
                        }
                    } catch (e) {}
                }
            } catch (e) {}

            // Fallback: fetch the bundled ace.js and attempt to extract a version string
            $.get('/plugins/compose.manager/javascript/ace/ace.js', function(data) {
                var m = null;
                // common patterns: ace.version = '1.4.12' or "version: '1.4.12'" or ace-builds-1.4.12
                m = data.match(/ace\.version\s*=\s*['\"]([\w\.\-]+)['\"]/i) || data.match(/version\s*[:=]\s*['\"]([\w\.\-]+)['\"]/i) || data.match(/ace-builds[-_]?([\d\.\-]+)/i);
                if (m && m[1]) {
                    setVersion(m[1]);
                } else {
                    setVersion('unknown');
                }
            }).fail(function() {
                setVersion('unknown');
            });
        })();
    </script>
